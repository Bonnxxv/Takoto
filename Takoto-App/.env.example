# Salin file ini menjadi .env dan isi nilainya sebelum build

# Google OAuth Client ID (untuk login editor)
# Buat di Google Cloud Console > Credentials > OAuth 2.0 Client IDs > Desktop App
VITE_GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# Service Account credentials (untuk upload ke Google Drive owner)
# 1. Buat Service Account di Google Cloud Console
# 2. Download JSON credentials
# 3. Encode ke base64: base64 -i credentials.json | tr -d '\n'
# 4. Paste hasilnya di sini
VITE_GOOGLE_SERVICE_ACCOUNT=base64_encoded_service_account_json_here

# ID folder utama di Google Drive milik owner
# Buka folder di Google Drive, copy ID dari URL:
# drive.google.com/drive/folders/THIS_IS_THE_ID
VITE_GOOGLE_DRIVE_FOLDER_ID=your_main_folder_id_here
